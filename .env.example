# ==========================================
# PLAYWRIGHT AGENT - ENVIRONMENT CONFIGURATION
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED variables are marked with [REQUIRED]
# OPTIONAL variables have sensible defaults
# ==========================================

# ==========================================
# AI/LLM CONFIGURATION [REQUIRED]
# ==========================================
# These are required for the AI agents to function.
#
# Supported providers:
#   Anthropic Direct (recommended):
#     ANTHROPIC_BASE_URL=https://api.anthropic.com
#     ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514
#
#   OpenRouter (free models available):
#     ANTHROPIC_BASE_URL=https://openrouter.ai/api
#     ANTHROPIC_DEFAULT_SONNET_MODEL=meta-llama/llama-3.2-3b-instruct:free

# [REQUIRED] Authentication token for Claude API
ANTHROPIC_AUTH_TOKEN=your-token-here

# [REQUIRED] API Base URL
ANTHROPIC_BASE_URL=https://api.anthropic.com

# [REQUIRED] Model selection
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250514

# ==========================================
# MEMORY SYSTEM (OPTIONAL)
# ==========================================
# The memory system enables pattern learning and coverage tracking.
# Requires OpenAI API key for embeddings (semantic search).

# Enable/disable memory system (default: true)
MEMORY_ENABLED=true

# OpenAI API key for embeddings (optional - memory features limited without this)
OPENAI_API_KEY=

# ChromaDB configuration (vector store for semantic search)
# ChromaDB runs in embedded mode - no separate server needed
# Data is persisted to this directory (auto-created if missing)
CHROMADB_PERSIST_DIRECTORY=./data/chromadb

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Memory retention settings
MEMORY_RETENTION_DAYS=365
MEMORY_COLLECTION_PREFIX=test_automation

# Coverage analysis
COVERAGE_ENABLED=true
COVERAGE_THRESHOLD=0.8

# ==========================================
# DATABASE CONFIGURATION (OPTIONAL)
# ==========================================
# Database is optional - SQLite is used by default for simplicity.
# PostgreSQL is recommended for web dashboard with multiple users.
#
# Connection string formats:
#   SQLite (default):     sqlite:///./test.db
#   PostgreSQL (local):   postgresql://postgres:postgres@localhost:5434/playwright_agent
#   PostgreSQL (docker):  postgresql://postgres:postgres@db:5432/playwright_agent

DATABASE_URL=sqlite:///./test.db

# ==========================================
# AUTHENTICATION CONFIGURATION (OPTIONAL)
# ==========================================
# Multi-user support requires these settings.
# Authentication is disabled by default for easy local development.

# [REQUIRED for auth] JWT secret key - generate with: openssl rand -hex 32
# IMPORTANT: Use a different key for each environment (dev, staging, prod)
JWT_SECRET_KEY=dev-secret-key-change-in-production

# Enable authentication enforcement (default: false for gradual migration)
# Set to true after setting up admin users and team
REQUIRE_AUTH=false

# Allow new user registration (default: true)
# Set to false if you want admin-only user creation
ALLOW_REGISTRATION=true

# Redis URL for distributed rate limiting (optional)
# Required for production with multiple server instances
# REDIS_URL=redis://localhost:6379/0

# ==========================================
# PLAYWRIGHT CONFIGURATION
# ==========================================
# Browser settings for test execution

# Run browsers in headed mode (true = visible browser window)
HEADLESS=false
PLAYWRIGHT_HEADLESS=false

# Base URL for tests (used by Playwright config)
BASE_URL=https://the-internet.herokuapp.com

# ==========================================
# SKILL MODE CONFIGURATION
# ==========================================
# Settings for Playwright skill-based execution.
# Skills provide an alternative to MCP tools for complex scenarios.

# Directory containing skill files (default: .claude/skills/playwright)
SKILL_DIR=.claude/skills/playwright

# Script execution timeout in milliseconds (default: 30000)
SKILL_TIMEOUT=30000

# Slow down skill actions by N milliseconds (useful for debugging)
SLOW_MO=0

# ==========================================
# TEST CREDENTIALS (SITE-SPECIFIC)
# ==========================================
# These are example credentials for testing demo sites.
# Replace with credentials for your target application.
#
# SECURITY NOTE: Never commit real credentials to version control.
# Use environment variables or secret management in production.

# The Internet Demo Site (https://the-internet.herokuapp.com)
LOGIN_USERNAME=tomsmith
LOGIN_PASSWORD=SuperSecretPassword!

# Add your own test credentials below:
# MY_APP_USERNAME=
# MY_APP_PASSWORD=

# ==========================================
# MINIO CONFIGURATION (PRODUCTION)
# ==========================================
# MinIO provides S3-compatible object storage for:
# - Off-site backups
# - Archived run artifacts
# - Long-term data retention
#
# Required for production deployments with data persistence.

# MinIO credentials - generate secure values: openssl rand -hex 16
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your-secure-password-here

# MinIO endpoint (internal Docker network)
MINIO_ENDPOINT=http://minio:9000

# MinIO ports (external access)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Bucket names
MINIO_BUCKET=playwright-backups
MINIO_BUCKET_ARTIFACTS=playwright-artifacts

# ==========================================
# BACKUP & ARCHIVAL CONFIGURATION
# ==========================================
# Controls data retention policies for test runs and artifacts.

# Days to keep backups locally (default: 30)
BACKUP_RETENTION=30

# Days to keep archived artifacts in MinIO (default: 90)
ARCHIVE_RETENTION=90

# Hot storage: Days to keep all artifacts locally (default: 30)
ARCHIVE_HOT_DAYS=30

# Total retention: Days before artifacts are deleted completely (default: 90)
ARCHIVE_TOTAL_DAYS=90

# ==========================================
# VNC LIVE BROWSER VIEW (Admin-Only)
# ==========================================
# VNC provides real-time browser streaming for administrators during test execution.
# Uses Xvfb (virtual display) + x11vnc + websockify for WebSocket-based viewing.

# Enable/disable VNC mode (default: true in Docker production)
# When enabled, browser runs in headed mode on virtual display :99
VNC_ENABLED=true

# Virtual display number for Xvfb (default: :99)
DISPLAY=:99

# ==========================================
# BROWSER RESOURCE POOL CONFIGURATION
# ==========================================
# The unified browser pool limits ALL browser operations (test runs,
# explorations, agents, PRD processing) to prevent resource exhaustion.

# Maximum concurrent browser instances (default: 5)
# This is a HARD LIMIT across all operation types
MAX_BROWSER_INSTANCES=5

# Maximum seconds to wait for a browser slot (default: 3600 = 1 hour)
BROWSER_SLOT_TIMEOUT=3600

# ==========================================
# AGENT TIMEOUT CONFIGURATION
# ==========================================
# Controls how long AI agents can run before timing out.
# These are useful for preventing runaway agents and managing costs.

# Default timeout for all agents in seconds (default: 1800 = 30 minutes)
AGENT_TIMEOUT_SECONDS=1800

# Per-agent timeout overrides (all default to AGENT_TIMEOUT_SECONDS if not set)
# Exploration agent timeout (discovering pages and flows)
EXPLORATION_TIMEOUT_SECONDS=1800
# Planner agent timeout (generating test plans from specs/PRD)
PLANNER_TIMEOUT_SECONDS=1800
# Generator agent timeout (converting specs to Playwright code)
GENERATOR_TIMEOUT_SECONDS=1800

# ==========================================
# PRODUCTION DOCKER CONFIGURATION
# ==========================================
# These are used by docker-compose.prod.yml for production deployments.

# PostgreSQL credentials (required for production)
POSTGRES_USER=playwright
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=playwright_agent

# Parallel execution settings (legacy - see MAX_BROWSER_INSTANCES above)
PARALLEL_MODE_ENABLED=true
DEFAULT_PARALLELISM=5

# Initial admin user (created automatically on first startup)
# Change these before your first 'make prod-dev' or 'make setup'
INITIAL_ADMIN_EMAIL=admin@test.com
INITIAL_ADMIN_PASSWORD=Admin123!@#

# Frontend URL for API communication
NEXT_PUBLIC_API_URL=http://localhost:8001
